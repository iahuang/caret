{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Caret",
    "version": "0.0.1",
    "identifier": "dev.ianhuang.caret",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "bun run dev",
        "beforeBuildCommand": "bun run build"
    },
    "app": {
        "windows": [
            {
                "title": "Caret",
                "width": 1100,
                "height": 720,
                "minWidth": 600,
                "minHeight": 400,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "trafficLightPosition": { "x": 16, "y": 18 }
            }
        ],
        "security": {
            "csp": null
        },
        "macOSPrivateApi": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.png"
        ],
        "fileAssociations": [
            {
                "ext": ["md", "markdown"],
                "name": "Markdown",
                "description": "Markdown document",
                "role": "Editor",
                "rank": "Default"
            }
        ]
    }
}
